# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Supabase project URL (found in Supabase → Settings → API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (safe to expose in the browser)
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: override the client-side admin gate code for the poster builder
# VITE_POSTER_ADMIN_CODE=1234
